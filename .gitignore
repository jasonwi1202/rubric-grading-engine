# =============================================================================
# Rubric Grading Engine — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.cover
*.coverage.*

# pyproject build artifacts
*.spec

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
.npm
.yarn/
.pnp.js

# Next.js
frontend/.next/
frontend/out/

# Vitest / Jest
frontend/coverage/

# TypeScript
*.tsbuildinfo

# Misc JS artifacts
.parcel-cache/
.turbo/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Alembic
# -----------------------------------------------------------------------------
# Do NOT ignore migrations — they must be committed
# backend/app/db/migrations/versions/ is intentionally tracked

# -----------------------------------------------------------------------------
# IDE & editor
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# JetBrains
*.iml
*.iws
.idea/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Uploads & generated files (local dev only — production uses S3)
# -----------------------------------------------------------------------------
uploads/
exports/
media/

# -----------------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------------
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# MinIO local data (Docker Compose volume)
# -----------------------------------------------------------------------------
.minio-data/

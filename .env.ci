# CI environment — safe non-secret values for the Docker Compose E2E stack.
# All "secrets" here are fixed test values with no production use.
# This file is intentionally committed and contains no real credentials.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rubric_grading
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://redis:6379/0
REDIS_GRADING_TTL_SECONDS=3600
CELERY_WORKER_CONCURRENCY=2
GRADING_TASK_SOFT_TIME_LIMIT=120
GRADING_TASK_HARD_TIME_LIMIT=180

# Fixed test secrets — not used in production
JWT_SECRET_KEY=ci-test-jwt-secret-key-minimum-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

EMAIL_VERIFICATION_HMAC_SECRET=ci-test-hmac-secret-key-minimum-32-characters
UNSUBSCRIBE_HMAC_SECRET=ci-test-unsubscribe-secret-minimum-32-characters-ok
VERIFICATION_TOKEN_TTL_SECONDS=86400
FRONTEND_URL=http://localhost:3000

# OpenAI — not called during E2E tests (no grading in M2)
OPENAI_API_KEY=sk-not-used-in-e2e-tests
OPENAI_GRADING_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
GRADING_PROMPT_VERSION=v1

# MinIO
S3_BUCKET_NAME=rubric-grading-local
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_PRESIGNED_URL_EXPIRE_SECONDS=3600

# SMTP — Mailpit in the Docker Compose stack
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_TLS=false
SMTP_FROM_EMAIL=noreply@example.com
CONTACT_EMAIL=team@example.com

INTEGRITY_PROVIDER=internal
INTEGRITY_SIMILARITY_THRESHOLD=0.25
INTEGRITY_AI_LIKELIHOOD_THRESHOLD=0.7

ENVIRONMENT=development
LOG_LEVEL=WARNING
CORS_ORIGINS=http://localhost:3000
MAX_ESSAY_FILE_SIZE_MB=10
MAX_BATCH_SIZE=100
# Disable rate limiting in CI — E2E tests create multiple accounts per run
# and would exhaust the 5/hr signup limit from a single CI runner IP.
RATE_LIMIT_ENABLED=false

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_ENV=test
GRADING_POLL_INTERVAL_MS=3000

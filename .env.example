# =============================================================================
# Rubric Grading Engine — Environment Variables
# Copy this file to .env and fill in all required values before running.
# .env is gitignored. Never commit real secrets.
# Full documentation: docs/architecture/configuration.md
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rubric_grading
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_GRADING_TTL_SECONDS=3600

# Celery (defaults to REDIS_URL — override only if using a separate broker)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=4
GRADING_TASK_SOFT_TIME_LIMIT=120
GRADING_TASK_HARD_TIME_LIMIT=180

# -----------------------------------------------------------------------------
# Authentication
# REQUIRED — must be at least 32 characters. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_generate_a_real_secret_minimum_32_characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# OpenAI
# REQUIRED — get your key at https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_GRADING_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
GRADING_PROMPT_VERSION=v1

# -----------------------------------------------------------------------------
# File Storage (MinIO for local dev, S3 for staging/production)
# -----------------------------------------------------------------------------
S3_BUCKET_NAME=rubric-grading-local
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
# Override endpoint for MinIO local dev — remove this in production
S3_ENDPOINT_URL=http://minio:9000
S3_PRESIGNED_URL_EXPIRE_SECONDS=3600

# -----------------------------------------------------------------------------
# Academic Integrity (optional — defaults to internal similarity only)
# Set INTEGRITY_PROVIDER=originality_ai or winston_ai and supply an API key
# to enable third-party detection.
# -----------------------------------------------------------------------------
INTEGRITY_PROVIDER=internal
# INTEGRITY_API_KEY=
INTEGRITY_SIMILARITY_THRESHOLD=0.25
INTEGRITY_AI_LIKELIHOOD_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
MAX_ESSAY_FILE_SIZE_MB=10
MAX_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# NEXT_PUBLIC_* variables are exposed to the browser — no secrets here.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_ENV=development
GRADING_POLL_INTERVAL_MS=3000
